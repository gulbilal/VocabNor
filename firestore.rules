rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.uid == uid
        && request.resource.data.authProvider in ['password', 'google'];
      allow update: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.username == resource.data.username
        && request.resource.data.usernameLower == resource.data.usernameLower;
      allow delete: if false;

      match /highScores/{document} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    match /usernames/{usernameLower} {
      allow get: if true;
      allow list: if false;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && !exists(/databases/$(database)/documents/usernames/$(usernameLower))
        && existsAfter(/databases/$(database)/documents/users/$(request.auth.uid))
        && getAfter(/databases/$(database)/documents/users/$(request.auth.uid)).data.usernameLower == usernameLower
        && getAfter(/databases/$(database)/documents/users/$(request.auth.uid)).data.username == request.resource.data.username;
      allow update, delete: if false;
    }
  }
}
